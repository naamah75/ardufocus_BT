<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.04"
                    android:text="ArduFocus Controller"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/deviceSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="@color/accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connectButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Connetti"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="18dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Disconnesso"
                    android:textColor="@color/accent_soft" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/stepLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="sans-serif-monospace"
                    android:text="Fuocheggiamento"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/ic_focus_badge_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingTop="10dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-monospace"
                        android:text="Posizione"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/positionValueText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-monospace"
                        android:gravity="end"
                        android:text="--"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/backwardButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_backward"
                        android:contentDescription="Indietro"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_focus_backward"
                        app:tint="@null" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/forwardButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_forward"
                        android:contentDescription="Avanti"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_focus_forward"
                        app:tint="@null" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward1Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="1"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward5Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="5"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward10Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="10"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward50Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="50"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward100Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:text="100"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/backward500Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:text="500"
                                app:backgroundTint="@color/backward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward1Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="1"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward5Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="5"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward10Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="10"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward50Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:text="50"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward100Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:text="100"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/forward500Button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="11sp"
                                android:text="500"
                                app:backgroundTint="@color/forward_pastel"
                                app:cornerRadius="14dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/stopButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_neutral"
                        android:contentDescription="STOP"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_focus_stop"
                        app:tint="@null" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/posButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_button_neutral"
                        android:contentDescription="POS"
                        android:padding="14dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_focus_info"
                        app:tint="@null" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/log_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/logLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-monospace"
                    android:text="Telemetria ArduFocus"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/white" />

                <ScrollView
                    android:id="@+id/logScroll"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_marginTop="12dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/logText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/log_text"
                        android:textIsSelectable="true"
                        android:typeface="monospace" />
                </ScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
