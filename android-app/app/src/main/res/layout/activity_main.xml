<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/navTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/panel_bg"
            app:tabInlineLabel="true"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/accent_soft"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed"
            app:tabRippleColor="@android:color/transparent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/connectionPageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/panel_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/deviceSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:backgroundTint="@color/accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connectButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-monospace"
                        android:text="Connetti"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Disconnesso"
                    android:textColor="@color/accent_soft" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/connectionDisclaimerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_neutral"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-monospace"
                android:text="ArduFocus controller"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-monospace"
                android:text="github.com/naamah75/ardufocus_BT"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-monospace"
                android:text="versione 0.3-BT"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/focusPageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/pip_bg"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/pip_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/positionValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_neutral"
                        android:fontFamily="@font/dseg7_classic_regular"
                        android:gravity="center"
                        android:minWidth="220dp"
                        android:paddingLeft="18dp"
                        android:paddingTop="12dp"
                        android:paddingRight="18dp"
                        android:paddingBottom="12dp"
                        android:text="--"
                        android:textColor="@color/pip_text"
                        android:textSize="42sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/backwardButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-monospace"
                        app:backgroundTint="@color/pip_button_bg"
                        android:text=""
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_focus_backward"
                        app:iconGravity="textTop"
                        app:iconPadding="0dp"
                        app:iconTint="@color/pip_text"
                        app:iconSize="36dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/forwardButton"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-monospace"
                        app:backgroundTint="@color/pip_button_bg"
                        android:text=""
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_focus_forward"
                        app:iconGravity="textTop"
                        app:iconPadding="0dp"
                        app:iconTint="@color/pip_text"
                        app:iconSize="36dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step1Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="1"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step2Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="2"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step5Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="5"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step10Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="10"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step25Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="25"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step50Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="50"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step100Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="100"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step250Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="250"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/step500Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/vt323_regular"
                            android:maxLines="1"
                            android:text="500"
                            android:textColor="@color/pip_text"
                            android:textSize="28sp"
                            app:backgroundTint="@color/pip_button_bg_alt"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/stopButton"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/vt323_regular"
                    app:backgroundTint="@color/pip_button_bg"
                    android:text="STOP"
                    android:textColor="@color/pip_text"
                    android:textSize="20sp"
                    app:cornerRadius="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/telemetryPreviewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_pip_panel"
            android:fontFamily="@font/vt323_regular"
            android:minHeight="72dp"
            android:padding="12dp"
            android:text="--"
            android:textColor="@color/pip_text"
            android:textSize="22sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/telemetryPageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/pip_bg"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/pip_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <ScrollView
                    android:id="@+id/logScroll"
                    android:layout_width="match_parent"
                    android:layout_height="520dp"
                    android:fillViewport="true">

                    <TextView
                        android:id="@+id/logText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/vt323_regular"
                        android:letterSpacing="0.04"
                        android:textColor="@color/pip_text"
                        android:textSize="24sp"
                        android:textIsSelectable="true"
                        android:typeface="monospace" />
                </ScrollView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/infoButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/vt323_regular"
            android:text="INFO"
            android:textColor="@color/pip_text"
            android:textSize="20sp"
            app:backgroundTint="@color/pip_button_bg"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
